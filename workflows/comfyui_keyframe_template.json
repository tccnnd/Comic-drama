    "inputs": {
      "ckpt_name": "__CHECKPOINT_NAME__"
    },
    "_meta": {"title": "Checkpoint"}
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "__PROMPT__"
    },
    "_meta": {"title": "POSITIVE"}
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "__NEGATIVE__"
