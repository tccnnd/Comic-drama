      "weight_type": "standard",
      "start_at": 0,
      "end_at": 1
    },
    "_meta": {
      "title": "IPADAPTER_MAIN"
    }
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "__SEED__",
      "steps": "__STEPS__",
      "cfg": "__CFG__",
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 1,
      "model": [
        "7",
        0
      ],
      "positive": [
        "3",
        0
      ],
      "negative": [
        "4",
        0
      ],
      "latent_image": [
        "5",
        0
      ]
    },
    "_meta": {
      "title": "K采样器"
    }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": [
        "8",
        0
      ],
      "vae": [
        "1",
        2
      ]
    },
    "_meta": {
      "title": "VAE解码"
    }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "comicdrama_ipadapter",
      "images": [
        "9",
        0
      ]
    },
    "_meta": {
      "title": "保存图像"
    }
  },
  "11": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": [
        "1",
        0
      ],
      "clip": [
        "1",
        1
      ],
