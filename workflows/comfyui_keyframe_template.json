    "_meta": {
      "title": "CHARACTER_REF_IMAGE"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": [
        "11",
        1
      ],
      "text": "__PROMPT__\n__CHARACTER_DESCRIPTIONS__"
    },
    "_meta": {
      "title": "SCENE_PROMPT_POSITIVE"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": [
        "11",
        1
      ],
