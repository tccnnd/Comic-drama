# Any OpenAI-compatible chat completion endpoint can be used.
# Examples:
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4.1-mini

LLM_API_KEY=replace-with-your-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
VOICE_PRESETS_PATH=voice_presets.json

# Keyframe generation.
# local: built-in placeholder renderer; auto: try ComfyUI then fallback; comfyui: require ComfyUI.
KEYFRAME_PROVIDER=auto
# Scene video generation.
# local: keyframe PNG -> 2.5D motion clip; comfyui: self-hosted video workflow, with local fallback unless VIDEO_STRICT=1.
VIDEO_PROVIDER=local
VIDEO_STRICT=0
VIDEO_STRUCTURED_SPEC_MODE=auto
VIDEO_SEND_STRUCTURED_SPEC=0
# 1 means ComfyUI errors fail loudly instead of silently creating local placeholder art.
COMFYUI_STRICT=0

# ComfyUI integration. COMFYUI_WORKFLOW_PATH must point to an exported API-format workflow JSON.
COMFYUI_BASE_URL=http://127.0.0.1:8188
# Cloud ComfyUI via SSH tunnel managed inside the backend:
# COMFYUI_SSH_HOST=sc01-ssh.gpuhome.cc
# COMFYUI_SSH_PORT=30935
# COMFYUI_SSH_USER=root
# COMFYUI_SSH_PASSWORD=replace-with-your-password
# CLOUD_COMFYUI_SSH_HOST=sc01-ssh.gpuhome.cc
# CLOUD_COMFYUI_SSH_PORT=30935
# CLOUD_COMFYUI_SSH_USER=root
# CLOUD_COMFYUI_SSH_PASSWORD=replace-with-your-password
# COMFYUI_SSH_LOCAL_HOST=127.0.0.1
# COMFYUI_SSH_LOCAL_PORT=8189
# COMFYUI_SSH_REMOTE_HOST=127.0.0.1
# COMFYUI_SSH_REMOTE_PORT=8188
# Optional for cloud providers. Examples:
# COMFYUI_AUTH_HEADER=Authorization: Bearer sk-xxx
# COMFYUI_API_KEY=sk-xxx
COMFYUI_AUTH_HEADER=
COMFYUI_API_KEY=
COMFYUI_WORKFLOW_PATH=workflows/comfyui_keyframe_template.json
COMFYUI_VIDEO_WORKFLOW_PATH=workflows/comfyui_video_template.json
COMFYUI_VIDEO_CHECKPOINT_NAME=
COMFYUI_VIDEO_LORA_NAME=
COMFYUI_VIDEO_LORA_STRENGTH_MODEL=0.7
COMFYUI_VIDEO_LORA_STRENGTH_CLIP=0.7
COMFYUI_VIDEO_IP_ADAPTER_WEIGHT=0.65
COMFYUI_VIDEO_STRUCTURED_SPEC_MODE=auto
COMFYUI_VIDEO_SEND_STRUCTURED_SPEC=0
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=24
VIDEO_STEPS=18
VIDEO_CFG=6.5
# Set this to your ComfyUI input directory so role reference images can be copied for LoadImage nodes.
# Example: COMFYUI_INPUT_DIR=E:\ComfyUI\input
COMFYUI_INPUT_DIR=
# auto: copy into local ComfyUI input dir for localhost, upload via /upload/image for remote cloud ComfyUI.
# upload: always upload reference images to ComfyUI input.
# absolute: send the local absolute path directly, only useful when backend and ComfyUI share a filesystem.
COMFYUI_REFERENCE_MODE=auto
COMFYUI_IP_ADAPTER_WEIGHT=0.65
COMFYUI_WIDTH=512
COMFYUI_HEIGHT=768
COMFYUI_STEPS=12
COMFYUI_CFG=7

# Optional if you switch COMFYUI_WORKFLOW_PATH to workflows/comfyui_faceid_template.json
COMFYUI_FACEID_LORA_STRENGTH=0.6
COMFYUI_FACEID_WEIGHT=2.0

# Standard IPAdapter Plus files expected by the plugin:
# - ComfyUI\models\ipadapter\ip-adapter-plus_sd15.safetensors
# - ComfyUI\models\clip_vision\CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors
#
# Optional FaceID template kept for later:
# - workflows/comfyui_faceid_template.json
